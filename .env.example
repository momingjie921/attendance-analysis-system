# 本地开发示例。复制为 .env 后，请替换所有占位值。
SECRET_KEY=replace-with-a-long-random-secret

# MySQL 示例。请使用本机数据库账号和密码。
DATABASE_URI=mysql+pymysql://attendance_user:your_password@127.0.0.1:3306/attendance_system

HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=True

# 邮件配置本地开发可选。不要提交真实 SMTP 密钥。
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_SENDER=your_email@example.com

SESSION_COOKIE_SECURE=False
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
API_CSRF_PROTECT=True
ENABLE_DEMO_DATA=True
